data/
data/narrative_cache/   # LLM narrative disk cache (Step 3; already under data/)
*.parquet

# ── Python ────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── 虚拟环境 ──────────────────────────────────
.venv/
venv/
env/

# ── 研究报告输出（本地生成，不纳入版本控制）──
research/

# ── Claude Code 本地权限配置（含机器特定路径）──
.claude/settings.local.json

# ── IDE / OS ──────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Jupyter ───────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Codex local agent tooling (machine-local) ─
.codex/

# ── Stray git worktree gitlink (accidental embed, no .gitmodules) ──
.claude/worktrees/

# ── Windows "mark of the web" alternate-data-stream cruft ──
*Zone.Identifier

# ── Generated calibration backfill outputs (regenerated by the tool; dated) ──
docs/calibration/fragility_backfill_*
docs/calibration/fragility_volshrink_*

# ── Diagnostic scripts (throwaway; only README tracked) ──
scripts/diag/*
!scripts/diag/README.md
