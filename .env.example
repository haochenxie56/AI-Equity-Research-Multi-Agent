# Copy this file to .env and fill in your API keys.
# .env is git-ignored and must NOT be committed.

# polygon.io API key (fallback data source)
POLYGON_API_KEY=your_polygon_api_key_here

# Anthropic API key (for Claude agent integration)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Finnhub API key (news & sentiment — free tier sufficient)
# Register at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# ---------------------------------------------------------------------------
# Reliability layer feature flags (Phase 2A — all OFF by default)
# ---------------------------------------------------------------------------
# These flags control the evidence-first reliability orchestration layer.
# All flags default to the safe, non-invasive state shown below.
# Do NOT enable any flag in production until the corresponding phase is
# complete and validated via dry-run monitoring.
#
# Master switch — set to "true" only from Phase 2B onward
# RELIABILITY_ENABLED=false
#
# Dry-run mode: collect artifacts without altering user-facing output
# RELIABILITY_DRY_RUN=true
#
# Block workflow on failed validation (strict mode — Phase 2E+)
# RELIABILITY_BLOCK_ON_VALIDATION_ERROR=false
#
# Show evidence trace panels in Streamlit (Phase 2F+)
# RELIABILITY_SHOW_UI_TRACE=false
#
# Use constrained AgentResult prompt contract (Phase 2D+)
# RELIABILITY_USE_CONSTRAINED_PROMPTS=false
#
# Retry with repair prompt on validation failure (Phase 2E+)
# RELIABILITY_ENABLE_REPAIR_PROMPT=false
